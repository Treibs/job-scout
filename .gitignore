# ── personal data — NEVER commit ────────────────────────────────────────────
resume/resume.md
config/*.yaml
!config/*.example.yaml
.env
service_account.json
*service_account*.json

# ── python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── local state scratch (the committed state/ files are added explicitly) ─────
state/*.local
.DS_Store

# ── CSV tracker output — personal job data, keep local (never commit) ─────────
output/

# ── screenshots / images — never commit (can capture personal desktop data) ───
*.png
*.jpg
*.jpeg
!docs/dashboard.png   # the one intentional, curated README asset

# ── runtime dedup state — kept LOCAL for the Kitsune cron deployment (this disk
#    persists between runs, unlike CI). Holds personal job history; don't commit.
state/seen_hashes.json
state/snapshot.sqlite
state/linkedin_jd_cache.json
state/discovery.json
