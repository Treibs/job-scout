# Copy to .env for local dev. CI reads these from GitHub Secrets instead.
# Never commit real values.

# ── LLM scoring ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=             # optional: point scoring at an Anthropic-compatible
                                # endpoint (e.g. a MiniMax/other gateway). The SDK honors it.

# ── sink ─────────────────────────────────────────────────────────────────────
JOB_SCOUT_SINK=csv              # "csv" (default, no cloud) or "google_sheets"
JOBS_CSV_PATH=                  # optional, default output/jobs.csv

# Google Sheets sink only:
GOOGLE_SERVICE_ACCOUNT_JSON=    # full JSON blob, or a path to the key file in local dev
SHEET_ID=

# ── scraping ─────────────────────────────────────────────────────────────────
PROXY_URLS=                     # optional, comma-separated  user:pass@host:port
JOB_SCOUT_LINKEDIN_DELAY=2,5    # optional, "lo,hi" seconds between LinkedIn JD fetches
